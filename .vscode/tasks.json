{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run app (Windows)",
            "type": "shell",
            // -t:Run breaks on paths with spaces (MSB3073/9009: unquoted RunCommand),
            // so build and launch the exe explicitly.
            "command": "dotnet build src/SimpleGymDiary.App -f net10.0-windows10.0.19041.0; if ($LASTEXITCODE -eq 0) { Start-Process '${workspaceFolder}\\src\\SimpleGymDiary.App\\bin\\Debug\\net10.0-windows10.0.19041.0\\win-x64\\SimpleGymDiary.App.exe' }",
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Run app (Android)",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "src/SimpleGymDiary.App",
                "-f", "net10.0-android",
                "-t:Run"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Run tests",
            "type": "shell",
            "command": "dotnet",
            "args": ["test", "tests/SimpleGymDiary.Tests"],
            "group": "test",
            "problemMatcher": "$msCompile"
        }
    ]
}
