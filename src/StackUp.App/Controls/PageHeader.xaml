<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StackUp.App.Controls.PageHeader"
             x:Name="Root">
    <!-- Tab-page header: big title, brand accent bar, one-line description.
         Replaces the plain Shell nav bar on the four root tabs. -->
    <VerticalStackLayout Spacing="6">
        <Label Text="{Binding Title, Source={x:Reference Root}}"
               FontFamily="OpenSansSemibold"
               FontSize="28" />
        <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2"
                 HorizontalOptions="Start"
                 Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
        <Label Text="{Binding Subtitle, Source={x:Reference Root}}"
               Style="{StaticResource Hint}" />
    </VerticalStackLayout>
</ContentView>
