<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:strings="clr-namespace:StackUp.App.Resources.Strings"
             x:Class="StackUp.App.Controls.ProgressionExplainerView"
             x:Name="Root">
    <!-- Dimmed full-screen overlay; host pages toggle IsVisible and provide CloseCommand. -->
    <Grid BackgroundColor="#A0000000">
        <Border Style="{StaticResource Card}"
                Margin="24"
                MaximumWidthRequest="420"
                VerticalOptions="Center" HorizontalOptions="Fill"
                Padding="24">
            <VerticalStackLayout Spacing="14">
                <Label Text="{x:Static strings:AppStrings.Explainer_Title}"
                       FontFamily="OpenSansSemibold" FontSize="20"
                       HorizontalOptions="Center" />

                <Grid ColumnDefinitions="28,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="6">
                    <Label Text="▬" TextColor="{StaticResource MarkKeep}" FontSize="16" />
                    <Label Grid.Column="1" Text="{x:Static strings:AppStrings.Explainer_Keep}" FontSize="14" />
                    <Label Grid.Row="1" Text="▲" TextColor="{StaticResource MarkUp}" FontSize="16" />
                    <Label Grid.Row="1" Grid.Column="1" Text="{x:Static strings:AppStrings.Explainer_Up}" FontSize="14" />
                    <Label Grid.Row="2" Text="▼" TextColor="{StaticResource MarkDown}" FontSize="16" />
                    <Label Grid.Row="2" Grid.Column="1" Text="{x:Static strings:AppStrings.Explainer_Down}" FontSize="14" />
                </Grid>

                <Label Text="{x:Static strings:AppStrings.Explainer_Override}"
                       Style="{StaticResource Hint}" />

                <Button Text="{x:Static strings:AppStrings.Explainer_GotIt}"
                        FontFamily="OpenSansSemibold"
                        HeightRequest="50" CornerRadius="12"
                        Command="{Binding CloseCommand, Source={x:Reference Root}}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
