<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StackUp.App.ViewModels"
             xmlns:strings="clr-namespace:StackUp.App.Resources.Strings"
             xmlns:controls="clr-namespace:StackUp.App.Controls"
             x:Class="StackUp.App.Views.WorkoutHomePage"
             x:DataType="vm:WorkoutHomeViewModel"
             Title="{x:Static strings:AppStrings.Tab_Workout}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Padding="16" RowSpacing="12">

        <controls:PageHeader Title="{x:Static strings:AppStrings.Tab_Workout}"
                             Subtitle="{x:Static strings:AppStrings.Header_WorkoutSubtitle}" />

        <!-- Resume banner -->
        <Border Grid.Row="1" Style="{StaticResource Card}"
                IsVisible="{Binding HasInProgress}"
                BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Tertiary}}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ResumeCommand}" />
            </Border.GestureRecognizers>
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="2">
                    <Label Text="{x:Static strings:AppStrings.Home_SessionInProgress}" FontFamily="OpenSansSemibold" FontSize="16" />
                    <Label Text="{Binding InProgressText}" Style="{StaticResource Hint}" />
                </VerticalStackLayout>
                <Label Grid.Column="1" Text="›" FontSize="28" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
            </Grid>
        </Border>

        <Label Grid.Row="2"
               Text="{Binding MomentumText}"
               Style="{StaticResource Hint}"
               HorizontalOptions="Center" />

        <Label Grid.Row="3" Text="{x:Static strings:AppStrings.Home_StartASession}" Style="{StaticResource SectionTitle}" />

        <!-- One card per split; long-press (or mouse-drag) to reorder -->
        <CollectionView x:Name="SplitsCollection"
                        Grid.Row="4"
                        ItemsSource="{Binding Splits}"
                        CanReorderItems="True"
                        ReorderCompleted="OnSplitsReorderCompleted"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:SplitCardViewModel">
                    <Border Style="{StaticResource Card}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Label Text="&#xE25D;"
                                   FontFamily="MaterialIcons" FontSize="20"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <Label Text="{Binding Split.Name}" FontFamily="OpenSansSemibold" FontSize="20" />
                                <Label Text="{Binding LastDoneText}" Style="{StaticResource Hint}" />
                                <!-- last session's markings at a glance -->
                                <HorizontalStackLayout Spacing="10" IsVisible="{Binding HasMarks}">
                                    <Label Text="{Binding UpText}" FontSize="13" TextColor="{StaticResource MarkUp}" />
                                    <Label Text="{Binding KeepText}" FontSize="13" TextColor="{StaticResource MarkKeep}" />
                                    <Label Text="{Binding DownText}" FontSize="13" TextColor="{StaticResource MarkDown}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Button Grid.Column="2"
                                    Text="{x:Static strings:AppStrings.Home_Start}"
                                    FontFamily="OpenSansSemibold"
                                    HeightRequest="48"
                                    MinimumWidthRequest="96"
                                    CornerRadius="12"
                                    VerticalOptions="Center"
                                    Command="{Binding StartCommand, Source={RelativeSource AncestorType={x:Type vm:WorkoutHomeViewModel}}}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="{x:Static strings:AppStrings.Home_NoSplitsYet}"
                       Style="{StaticResource Hint}" HorizontalOptions="Center" Margin="0,32" />
            </CollectionView.EmptyView>
        </CollectionView>

    </Grid>
</ContentPage>
