<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StackUp.App.ViewModels"
             xmlns:controls="clr-namespace:StackUp.App.Controls"
             xmlns:strings="clr-namespace:StackUp.App.Resources.Strings"
             x:Class="StackUp.App.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{x:Static strings:AppStrings.Tab_Settings}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
    <controls:PageHeader Margin="16,16,16,0"
                         Title="{x:Static strings:AppStrings.Tab_Settings}"
                         Subtitle="{x:Static strings:AppStrings.Header_SettingsSubtitle}" />

    <ScrollView Grid.Row="1">
        <VerticalStackLayout Padding="16,12,16,16" Spacing="12">

            <Label Text="{x:Static strings:AppStrings.Settings_Units}" Style="{StaticResource SectionTitle}" />
            <Border Style="{StaticResource Card}">
                <!-- ItemsSource must bind before SelectedIndex, or the selection resets -->
                <Picker ItemsSource="{Binding UnitOptions}"
                        SelectedIndex="{Binding UnitIndex}" FontSize="16" />
            </Border>

            <Label Text="{x:Static strings:AppStrings.Settings_ProgressionDefaults}" Style="{StaticResource SectionTitle}" />
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="4">
                    <Label Text="{x:Static strings:AppStrings.Field_RepRangeMin}" Style="{StaticResource Hint}" />
                    <Entry Grid.Row="1" Text="{Binding RepMinText}" Keyboard="Numeric" />
                    <Label Grid.Column="1" Text="{x:Static strings:AppStrings.Field_RepRangeMax}" Style="{StaticResource Hint}" />
                    <Entry Grid.Row="1" Grid.Column="1" Text="{Binding RepMaxText}" Keyboard="Numeric" />

                    <Label Grid.Row="2" Text="{x:Static strings:AppStrings.Field_WeightIncrement}" Style="{StaticResource Hint}" Margin="0,8,0,0" />
                    <Entry Grid.Row="3" Text="{Binding IncrementText}" Keyboard="Numeric" />
                    <Label Grid.Row="2" Grid.Column="1" Text="{x:Static strings:AppStrings.Field_RepIncrement}" Style="{StaticResource Hint}" Margin="0,8,0,0" />
                    <Entry Grid.Row="3" Grid.Column="1" Text="{Binding RepIncrementText}" Keyboard="Numeric" />

                    <Label Grid.Row="4" Text="{x:Static strings:AppStrings.Field_SetsPerExercise}" Style="{StaticResource Hint}" Margin="0,8,0,0" />
                    <Entry Grid.Row="5" Text="{Binding SetCountText}" Keyboard="Numeric" />
                </Grid>
            </Border>

            <Label Text="{x:Static strings:AppStrings.Settings_CountingSetQuestion}" Style="{StaticResource SectionTitle}" />
            <Border Style="{StaticResource Card}">
                <Picker ItemsSource="{Binding CountingSetOptions}"
                        SelectedIndex="{Binding CountingSetRuleIndex}" FontSize="16" />
            </Border>

            <Label Text="{x:Static strings:AppStrings.Settings_Data}" Style="{StaticResource SectionTitle}" />
            <Button Text="{x:Static strings:AppStrings.Settings_CreateBackup}"
                    FontFamily="OpenSansSemibold"
                    HeightRequest="52" CornerRadius="12"
                    Command="{Binding CreateBackupCommand}" />
            <Button Text="{x:Static strings:AppStrings.Settings_RestoreBackup}"
                    HeightRequest="52" CornerRadius="12"
                    BackgroundColor="Transparent"
                    BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    BorderWidth="1"
                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    Command="{Binding RestoreBackupCommand}" />

            <Label Text="{x:Static strings:AppStrings.Settings_Help}" Style="{StaticResource SectionTitle}" />
            <Button Text="{x:Static strings:AppStrings.Settings_HowProgressionWorks}"
                    FontFamily="OpenSansSemibold"
                    HeightRequest="52" CornerRadius="12"
                    Command="{Binding ShowExplainerCommand}" />

            <Label Text="{x:Static strings:AppStrings.Settings_About}" Style="{StaticResource SectionTitle}" />
            <Button Text="{x:Static strings:AppStrings.Settings_SendFeedback}"
                    FontFamily="OpenSansSemibold"
                    HeightRequest="52" CornerRadius="12"
                    Command="{Binding SendFeedbackCommand}" />
            <Label Text="{Binding VersionText}"
                   Style="{StaticResource Hint}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>

    <!-- Re-openable "how progression works" overlay -->
    <controls:ProgressionExplainerView Grid.RowSpan="2"
                                       IsVisible="{Binding IsExplainerVisible}"
                                       CloseCommand="{Binding CloseExplainerCommand}" />
    </Grid>
</ContentPage>
