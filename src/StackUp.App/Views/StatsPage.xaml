<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StackUp.App.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:strings="clr-namespace:StackUp.App.Resources.Strings"
             xmlns:controls="clr-namespace:StackUp.App.Controls"
             x:Class="StackUp.App.Views.StatsPage"
             x:DataType="vm:StatsViewModel"
             Title="{x:Static strings:AppStrings.Tab_Stats}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="16,16,16,0" RowSpacing="10">

        <!-- Header with the filter toggle (was a toolbar item before the nav bar went away) -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <controls:PageHeader Title="{x:Static strings:AppStrings.Tab_Stats}"
                                 Subtitle="{x:Static strings:AppStrings.Header_StatsSubtitle}" />
            <Button Grid.Column="1"
                    Text="{x:Static strings:AppStrings.Stats_Filter}"
                    HeightRequest="40" CornerRadius="10" Padding="16,0"
                    VerticalOptions="Start"
                    Command="{Binding ToggleFilterCommand}" />
        </Grid>

        <!-- Range selection -->
        <HorizontalStackLayout Grid.Row="1" Spacing="8" HorizontalOptions="Center">
            <Button Text="{x:Static strings:AppStrings.Stats_Range3M}" WidthRequest="72" HeightRequest="40" CornerRadius="10" Padding="0"
                    Command="{Binding SetRangeCommand}" CommandParameter="0" />
            <Button Text="{x:Static strings:AppStrings.Stats_Range1Y}" WidthRequest="72" HeightRequest="40" CornerRadius="10" Padding="0"
                    Command="{Binding SetRangeCommand}" CommandParameter="1" />
            <Button Text="{x:Static strings:AppStrings.Stats_RangeAll}" WidthRequest="72" HeightRequest="40" CornerRadius="10" Padding="0"
                    Command="{Binding SetRangeCommand}" CommandParameter="2" />
        </HorizontalStackLayout>

        <!-- Filter panel: choose which exercises are charted (all on by default) -->
        <Border Grid.Row="2" Style="{StaticResource Card}" IsVisible="{Binding IsFilterOpen}">
            <VerticalStackLayout Spacing="4" BindableLayout.ItemsSource="{Binding FilterItems}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:StatFilterItemViewModel">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding Name}" FontSize="15" VerticalOptions="Center" />
                            <Switch Grid.Column="1" IsToggled="{Binding IsShown}"
                                    OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </Border>

        <!-- One chart card per visible exercise -->
        <ScrollView Grid.Row="3">
            <VerticalStackLayout Spacing="12" Padding="0,0,0,16"
                                 BindableLayout.ItemsSource="{Binding Cards}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:ExerciseStatCardViewModel">
                        <Border Style="{StaticResource Card}" Padding="12">
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Image Source="{Binding IconSource}"
                                           WidthRequest="20" HeightRequest="20"
                                           VerticalOptions="Center">
                                        <Image.Behaviors>
                                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                        </Image.Behaviors>
                                    </Image>
                                    <Label Grid.Column="1" Text="{Binding Title}" FontFamily="OpenSansSemibold" FontSize="16"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="{Binding Subtitle}" Style="{StaticResource Hint}"
                                           VerticalOptions="Center" />
                                </Grid>
                                <lvc:CartesianChart Series="{Binding Series}"
                                                    XAxes="{Binding XAxes}"
                                                    YAxes="{Binding YAxes}"
                                                    HeightRequest="200"
                                                    IsVisible="{Binding HasData}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
                <BindableLayout.EmptyView>
                    <Label Text="{x:Static strings:AppStrings.Stats_EmptyFiltered}"
                           Style="{StaticResource Hint}" HorizontalOptions="Center" Margin="0,32" />
                </BindableLayout.EmptyView>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
