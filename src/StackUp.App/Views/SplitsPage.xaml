<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StackUp.App.ViewModels"
             xmlns:strings="clr-namespace:StackUp.App.Resources.Strings"
             xmlns:controls="clr-namespace:StackUp.App.Controls"
             x:Class="StackUp.App.Views.SplitsPage"
             x:DataType="vm:SplitsViewModel"
             Title="{x:Static strings:AppStrings.Tab_Splits}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <controls:PageHeader Margin="16,16,16,0"
                             Title="{x:Static strings:AppStrings.Tab_Splits}"
                             Subtitle="{x:Static strings:AppStrings.Header_SplitsSubtitle}" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,12,16,96" Spacing="12"
                                 BindableLayout.ItemsSource="{Binding Splits}">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="vm:SplitListItemViewModel">
                    <Border Style="{StaticResource Card}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding OpenSplitCommand, Source={RelativeSource AncestorType={x:Type vm:SplitsViewModel}}}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Split.Name}" FontFamily="OpenSansSemibold" FontSize="17" />
                                <Label Text="{Binding Subtitle}" Style="{StaticResource Hint}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="›" FontSize="26" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray500}}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
            <BindableLayout.EmptyView>
                <Label Text="{x:Static strings:AppStrings.Splits_EmptyList}"
                       Style="{StaticResource Hint}" HorizontalOptions="Center" Margin="0,32" />
            </BindableLayout.EmptyView>
            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.RowSpan="2"
                Style="{StaticResource Fab}"
                SemanticProperties.Description="{x:Static strings:AppStrings.Splits_AddSemantic}"
                Command="{Binding AddSplitCommand}" />
    </Grid>
</ContentPage>
