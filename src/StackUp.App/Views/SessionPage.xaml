<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StackUp.App.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:controls="clr-namespace:StackUp.App.Controls"
             xmlns:strings="clr-namespace:StackUp.App.Resources.Strings"
             x:Class="StackUp.App.Views.SessionPage"
             x:DataType="vm:SessionViewModel"
             Title="{Binding Title}"
             Shell.TabBarIsVisible="False">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="?" Command="{Binding ShowExplainerCommand}" />
        <ToolbarItem Text="{Binding DeleteActionText}" Order="Secondary" Command="{Binding DeleteSessionCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- History navigation: browse this split's previous sessions (read-only) -->
        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,8,16,0" ColumnSpacing="8">
            <Button Text="‹"
                    FontSize="20"
                    WidthRequest="44" HeightRequest="40" CornerRadius="10" Padding="0"
                    BackgroundColor="Transparent"
                    BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    BorderWidth="1"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                    Command="{Binding GoPrevCommand}"
                    IsEnabled="{Binding CanGoPrev}" />
            <Label Grid.Column="1"
                   Text="{Binding HeaderText}"
                   FontFamily="OpenSansSemibold"
                   FontSize="14"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
            <Button Grid.Column="2" Text="›"
                    FontSize="20"
                    WidthRequest="44" HeightRequest="40" CornerRadius="10" Padding="0"
                    BackgroundColor="Transparent"
                    BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    BorderWidth="1"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                    Command="{Binding GoNextCommand}"
                    IsEnabled="{Binding CanGoNext}" />
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,16,16,8" Spacing="12"
                                 BindableLayout.ItemsSource="{Binding Entries}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:SessionEntryViewModel">
                        <Border Style="{StaticResource Card}" Padding="0">
                            <Grid ColumnDefinitions="4,*">
                                <!-- mark-colored accent stripe (transparent until reps are logged) -->
                                <BoxView Color="{Binding StripeColor}" />
                                <VerticalStackLayout Grid.Column="1" Spacing="10" Padding="14,16,16,16">

                                <!-- Row 1: icon + name + arrow badge -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <Image Source="{Binding IconSource}"
                                           WidthRequest="24" HeightRequest="24"
                                           VerticalOptions="Center">
                                        <Image.Behaviors>
                                            <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                        </Image.Behaviors>
                                    </Image>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}" FontFamily="OpenSansSemibold" FontSize="18" />
                                        <Label Text="{Binding TargetHint}" Style="{StaticResource Hint}" />
                                    </VerticalStackLayout>

                                    <!-- Arrow badge: tap cycles Down/Keep/Up (manual override) -->
                                    <Border Grid.Column="2"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12"
                                            BackgroundColor="{Binding MarkColor}"
                                            WidthRequest="52" HeightRequest="52">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding CycleMarkCommand}" Tapped="OnBadgeTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid>
                                            <Label Text="{Binding MarkGlyph}" TextColor="White" FontSize="20"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                            <!-- manual-override dot -->
                                            <BoxView IsVisible="{Binding IsManualMark}"
                                                     Color="White" CornerRadius="3"
                                                     WidthRequest="6" HeightRequest="6"
                                                     HorizontalOptions="End" VerticalOptions="Start"
                                                     Margin="0,6,6,0" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Row 2: weight stepper (weight-based only) -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12"
                                      IsVisible="{Binding IsWeightBased}">
                                    <Button Text="−" Style="{StaticResource StepperButton}"
                                            IsVisible="{Binding IsEditable}"
                                            Command="{Binding DecrementWeightCommand}" />
                                    <Grid Grid.Column="1" ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                        <Entry Text="{Binding WeightText}"
                                               Keyboard="Numeric"
                                               FontSize="34"
                                               FontFamily="OpenSansSemibold"
                                               HorizontalTextAlignment="Center"
                                               IsEnabled="{Binding IsEditable}"
                                               Placeholder="—" />
                                        <Label Grid.Column="1" Text="{Binding UnitLabel}"
                                               Style="{StaticResource Hint}" VerticalOptions="Center" />
                                    </Grid>
                                    <Button Grid.Column="2" Text="+" Style="{StaticResource StepperButton}"
                                            IsVisible="{Binding IsEditable}"
                                            Command="{Binding IncrementWeightCommand}" />
                                </Grid>

                                <!-- Row 3: rep chips (scroll horizontally if many sets) -->
                                <Label Text="{x:Static strings:AppStrings.Session_RepsPerSet}" Style="{StaticResource Hint}"
                                       FontSize="12" Margin="0,0,0,-6" />
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                    <ScrollView Orientation="Horizontal"
                                                HorizontalScrollBarVisibility="Never"
                                                VerticalOptions="Center">
                                        <HorizontalStackLayout Spacing="8"
                                                               BindableLayout.ItemsSource="{Binding Sets}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="vm:SetViewModel">
                                                    <Border StrokeThickness="1"
                                                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                                            StrokeShape="RoundRectangle 12">
                                                        <Entry Style="{StaticResource RepChipEntry}"
                                                               Text="{Binding RepsText}"
                                                               IsEnabled="{Binding IsEditable, Source={RelativeSource AncestorType={x:Type vm:SessionEntryViewModel}}}"
                                                               Placeholder="0" />
                                                    </Border>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </HorizontalStackLayout>
                                    </ScrollView>
                                    <Button Grid.Column="1"
                                            Text="+"
                                            FontSize="18"
                                            WidthRequest="44" HeightRequest="44" CornerRadius="12" Padding="0"
                                            BackgroundColor="Transparent"
                                            BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                            BorderWidth="1"
                                            TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                            IsVisible="{Binding IsEditable}"
                                            Command="{Binding AddSetCommand}" />
                                    <Button Grid.Column="2"
                                            Text="−"
                                            FontSize="18"
                                            WidthRequest="44" HeightRequest="44" CornerRadius="12" Padding="0"
                                            BackgroundColor="Transparent"
                                            BorderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                            BorderWidth="1"
                                            TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                            IsVisible="{Binding IsEditable}"
                                            Command="{Binding RemoveSetCommand}" />
                                </Grid>

                                <!-- Live consequence: what the current mark means for next time -->
                                <Label Text="{Binding ConsequenceText}"
                                       TextColor="{Binding MarkColor}"
                                       FontSize="13"
                                       IsVisible="{Binding IsConsequenceVisible}" />

                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Finish (hidden while browsing history) -->
        <Button Grid.Row="2"
                Text="{x:Static strings:AppStrings.Session_Finish}"
                FontFamily="OpenSansSemibold"
                FontSize="16"
                HeightRequest="56"
                CornerRadius="14"
                Margin="16,4,16,16"
                IsVisible="{Binding IsReadOnly, Converter={StaticResource InvertedBoolConverter}}"
                Command="{Binding FinishCommand}" />

        <!-- Finish summary overlay -->
        <Grid Grid.RowSpan="3"
              BackgroundColor="#A0000000"
              IsVisible="{Binding IsSummaryVisible}">
            <Border Style="{StaticResource Card}"
                    Margin="24"
                    MaximumWidthRequest="420"
                    VerticalOptions="Center" HorizontalOptions="Fill"
                    Padding="24">
                <VerticalStackLayout Spacing="16">
                    <Label Text="{x:Static strings:AppStrings.Session_Complete}"
                           FontFamily="OpenSansSemibold" FontSize="22"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding SummaryDuration}"
                           Style="{StaticResource Hint}"
                           HorizontalOptions="Center" />

                    <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                        <Label Text="{Binding SummaryStatsUp}" FontFamily="OpenSansSemibold" FontSize="18"
                               TextColor="{StaticResource MarkUp}" />
                        <Label Text="{Binding SummaryStatsKeep}" FontFamily="OpenSansSemibold" FontSize="18"
                               TextColor="{StaticResource MarkKeep}" />
                        <Label Text="{Binding SummaryStatsDown}" FontFamily="OpenSansSemibold" FontSize="18"
                               TextColor="{StaticResource MarkDown}" />
                    </HorizontalStackLayout>

                    <!-- Personal records (empty collection renders zero height) -->
                    <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding PrLines}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:SummaryLine">
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding Glyph}" TextColor="{Binding GlyphColor}"
                                           FontSize="14" VerticalOptions="Center" />
                                    <Label Text="{Binding Text}" FontSize="15" FontFamily="OpenSansSemibold"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}" />

                    <Label Text="{x:Static strings:AppStrings.Session_NextTime}" Style="{StaticResource SectionTitle}" Margin="0"
                           IsVisible="{Binding IsSummaryVisible}" />
                    <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding SummaryLines}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:SummaryLine">
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding Glyph}" TextColor="{Binding GlyphColor}"
                                           FontSize="14" VerticalOptions="Center" />
                                    <Label Text="{Binding Text}" FontSize="15" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <Button Text="{x:Static strings:AppStrings.Session_Done}"
                            FontFamily="OpenSansSemibold"
                            HeightRequest="50" CornerRadius="12"
                            Command="{Binding CloseSummaryCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- One-time "how progression works" explainer (also via the ? toolbar item) -->
        <controls:ProgressionExplainerView Grid.RowSpan="3"
                                           IsVisible="{Binding IsExplainerVisible}"
                                           CloseCommand="{Binding CloseExplainerCommand}" />
    </Grid>
</ContentPage>
