<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SimpleGymDiary.App.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Maui;assembly=LiveChartsCore.SkiaSharpView.Maui"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SimpleGymDiary.App.Views.StatsPage"
             x:DataType="vm:StatsViewModel"
             Title="Stats">

    <ContentPage.Resources>
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Padding="16" RowSpacing="12">

        <Border Style="{StaticResource Card}" Padding="12">
            <Picker Title="Exercise"
                    ItemsSource="{Binding Exercises}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedExercise}"
                    FontSize="16" />
        </Border>

        <HorizontalStackLayout Grid.Row="1" Spacing="8" HorizontalOptions="Center">
            <Button Text="3M" WidthRequest="72" HeightRequest="40" CornerRadius="10" Padding="0"
                    Command="{Binding SetRangeCommand}" CommandParameter="0" />
            <Button Text="1Y" WidthRequest="72" HeightRequest="40" CornerRadius="10" Padding="0"
                    Command="{Binding SetRangeCommand}" CommandParameter="1" />
            <Button Text="All" WidthRequest="72" HeightRequest="40" CornerRadius="10" Padding="0"
                    Command="{Binding SetRangeCommand}" CommandParameter="2" />
        </HorizontalStackLayout>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="8">
            <Grid>
                <lvc:CartesianChart Series="{Binding Series}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    IsVisible="{Binding HasData}" />
                <Label Text="{Binding EmptyText}"
                       IsVisible="{Binding HasData, Converter={StaticResource InvertedBoolConverter}}"
                       Style="{StaticResource Hint}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>
