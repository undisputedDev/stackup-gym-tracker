<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SimpleGymDiary.App.ViewModels"
             x:Class="SimpleGymDiary.App.Views.WorkoutHomePage"
             x:DataType="vm:WorkoutHomeViewModel"
             Title="Workout">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Resume banner -->
            <Border Style="{StaticResource Card}"
                    IsVisible="{Binding HasInProgress}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Tertiary}}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ResumeCommand}" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Session in progress" FontFamily="OpenSansSemibold" FontSize="16" />
                        <Label Text="{Binding InProgressText}" Style="{StaticResource Hint}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="›" FontSize="28" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                </Grid>
            </Border>

            <Label Text="{Binding MomentumText}"
                   Style="{StaticResource Hint}"
                   HorizontalOptions="Center"
                   Margin="0,4,0,0" />

            <Label Text="Start a session" Style="{StaticResource SectionTitle}" />

            <!-- One card per split -->
            <VerticalStackLayout Spacing="12" BindableLayout.ItemsSource="{Binding Splits}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:SplitCardViewModel">
                        <Border Style="{StaticResource Card}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                    <Label Text="{Binding Split.Name}" FontFamily="OpenSansSemibold" FontSize="20" />
                                    <Label Text="{Binding LastDoneText}" Style="{StaticResource Hint}" />
                                    <!-- last session's markings at a glance -->
                                    <HorizontalStackLayout Spacing="10" IsVisible="{Binding HasMarks}">
                                        <Label Text="{Binding UpText}" FontSize="13" TextColor="{StaticResource MarkUp}" />
                                        <Label Text="{Binding KeepText}" FontSize="13" TextColor="{StaticResource MarkKeep}" />
                                        <Label Text="{Binding DownText}" FontSize="13" TextColor="{StaticResource MarkDown}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <Button Grid.Column="1"
                                        Text="Start"
                                        FontFamily="OpenSansSemibold"
                                        HeightRequest="48"
                                        MinimumWidthRequest="96"
                                        CornerRadius="12"
                                        Command="{Binding StartCommand, Source={RelativeSource AncestorType={x:Type vm:WorkoutHomeViewModel}}}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
                <BindableLayout.EmptyView>
                    <Label Text="No splits yet — create one in the Splits tab."
                           Style="{StaticResource Hint}" HorizontalOptions="Center" Margin="0,32" />
                </BindableLayout.EmptyView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
