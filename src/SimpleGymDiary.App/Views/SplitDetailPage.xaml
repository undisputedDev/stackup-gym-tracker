<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SimpleGymDiary.App.ViewModels"
             xmlns:entities="clr-namespace:SimpleGymDiary.Core.Entities;assembly=SimpleGymDiary.Core"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SimpleGymDiary.App.Views.SplitDetailPage"
             x:DataType="vm:SplitDetailViewModel"
             Title="{Binding Name}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Rename" Command="{Binding RenameCommand}" />
        <ToolbarItem Text="Delete" Command="{Binding ArchiveSplitCommand}" Order="Secondary" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="10">

        <Label Text="Exercises (in workout order)" Style="{StaticResource SectionTitle}" />

        <!-- Long-press (or mouse-drag) a row to reorder -->
        <CollectionView x:Name="ExercisesCollection"
                        Grid.Row="1"
                        ItemsSource="{Binding Exercises}"
                        CanReorderItems="True"
                        ReorderCompleted="OnExercisesReorderCompleted"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="entities:Exercise">
                    <Border Style="{StaticResource Card}" Padding="12">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                            <Label Text="&#xE25D;"
                                   FontFamily="MaterialIcons" FontSize="20"
                                   VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
                            <Image Grid.Column="1"
                                   Source="{Binding IconKey, StringFormat='icon_{0}.png'}"
                                   WidthRequest="22" HeightRequest="22"
                                   Margin="4,0,4,0"
                                   VerticalOptions="Center">
                                <Image.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                </Image.Behaviors>
                            </Image>
                            <Label Grid.Column="2" Text="{Binding Name}" FontSize="16" VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding EditExerciseCommand, Source={RelativeSource AncestorType={x:Type vm:SplitDetailViewModel}}}"
                                        CommandParameter="{Binding .}" />
                                </Label.GestureRecognizers>
                            </Label>
                            <Button Grid.Column="3" Text="✕" FontSize="14"
                                    WidthRequest="40" HeightRequest="40" Padding="0" CornerRadius="10"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource MarkDown}"
                                    Command="{Binding RemoveExerciseCommand, Source={RelativeSource AncestorType={x:Type vm:SplitDetailViewModel}}}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <Label Text="Hold and drag to reorder · tap a name to edit its settings."
                       Style="{StaticResource Hint}" HorizontalTextAlignment="Center"
                       Margin="0,12,0,96" />
            </CollectionView.Footer>
            <CollectionView.EmptyView>
                <Label Text="No exercises yet — add your first one below."
                       Style="{StaticResource Hint}" HorizontalOptions="Center" Margin="0,24" />
            </CollectionView.EmptyView>
        </CollectionView>

        <Button Grid.RowSpan="2"
                Style="{StaticResource Fab}"
                Margin="0,0,4,4"
                SemanticProperties.Description="Add exercise"
                Command="{Binding AddExerciseCommand}" />
    </Grid>
</ContentPage>
