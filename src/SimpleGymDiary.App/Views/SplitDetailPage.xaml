<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SimpleGymDiary.App.ViewModels"
             xmlns:entities="clr-namespace:SimpleGymDiary.Core.Entities;assembly=SimpleGymDiary.Core"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SimpleGymDiary.App.Views.SplitDetailPage"
             x:DataType="vm:SplitDetailViewModel"
             Title="{Binding Name}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Rename" Command="{Binding RenameCommand}" />
        <ToolbarItem Text="Delete" Command="{Binding ArchiveSplitCommand}" Order="Secondary" />
    </ContentPage.ToolbarItems>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,96" Spacing="12">

            <Label Text="Exercises (in workout order)" Style="{StaticResource SectionTitle}" />

            <VerticalStackLayout Spacing="10" BindableLayout.ItemsSource="{Binding Exercises}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="entities:Exercise">
                        <Border Style="{StaticResource Card}" Padding="12">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="4">
                                <Image Source="{Binding IconKey, StringFormat='icon_{0}.png'}"
                                       WidthRequest="22" HeightRequest="22"
                                       Margin="4,0,8,0"
                                       VerticalOptions="Center">
                                    <Image.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                    </Image.Behaviors>
                                </Image>
                                <Label Grid.Column="1" Text="{Binding Name}" FontSize="16" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding EditExerciseCommand, Source={RelativeSource AncestorType={x:Type vm:SplitDetailViewModel}}}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Button Grid.Column="2" Text="↑" FontSize="16"
                                        WidthRequest="40" HeightRequest="40" Padding="0" CornerRadius="10"
                                        BackgroundColor="Transparent"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                        Command="{Binding MoveUpCommand, Source={RelativeSource AncestorType={x:Type vm:SplitDetailViewModel}}}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="3" Text="↓" FontSize="16"
                                        WidthRequest="40" HeightRequest="40" Padding="0" CornerRadius="10"
                                        BackgroundColor="Transparent"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                        Command="{Binding MoveDownCommand, Source={RelativeSource AncestorType={x:Type vm:SplitDetailViewModel}}}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="4" Text="✕" FontSize="14"
                                        WidthRequest="40" HeightRequest="40" Padding="0" CornerRadius="10"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource MarkDown}"
                                        Command="{Binding RemoveExerciseCommand, Source={RelativeSource AncestorType={x:Type vm:SplitDetailViewModel}}}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
                <BindableLayout.EmptyView>
                    <Label Text="No exercises yet — add your first one below."
                           Style="{StaticResource Hint}" HorizontalOptions="Center" Margin="0,24" />
                </BindableLayout.EmptyView>
            </VerticalStackLayout>

            <Label Text="Tap an exercise name to edit its settings (rep range, increment)."
                   Style="{StaticResource Hint}" HorizontalOptions="Center" />

            </VerticalStackLayout>
        </ScrollView>

        <Button Style="{StaticResource Fab}"
                SemanticProperties.Description="Add exercise"
                Command="{Binding AddExerciseCommand}" />
    </Grid>
</ContentPage>
